version: 2

project_name: my-cli

archives:
  - format: tar.gz
    format_overrides:
      - goos: windows
        format: zip
    files:
      - README.md

checksums:
  contents:
    - algorithm: sha256

release:
  github:
    owner: XuSen1210
    name: my-cli
  draft: true

snapshot:
  name_template: "{{ .Tag }}-next"
